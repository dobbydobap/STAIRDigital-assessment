# Normalize line endings: store LF in the repo, let the OS decide on checkout.
* text=auto eol=lf

# Keep CRLF for shells/files that need it on Windows.
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf
# Always treat these as binary.
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
screenshots/*.png filter=lfs diff=lfs merge=lfs -text
